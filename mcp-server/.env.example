# ==============================
# 模式一：统一机器人（单 App，路由多 AI）
# ==============================
FEISHU_APP_ID=cli_****************
FEISHU_APP_SECRET=********************************
FEISHU_USER_OPEN_ID=ou_********************************
# 默认 AI（直接发文本时调用）：claude / kimi / minimax / codex
DEFAULT_AI=claude

# ==============================
# 模式二：多智能体群聊协作（每个 AI 是群里独立成员）
# 每个 Agent 需要在飞书开放平台单独创建一个应用
# ==============================
# Claude Agent — 架构师
AGENT_CLAUDE_APP_ID=cli_****************
AGENT_CLAUDE_APP_SECRET=********************************

# Kimi Agent — 实现者
AGENT_KIMI_APP_ID=cli_****************
AGENT_KIMI_APP_SECRET=********************************

# MiniMax Agent — 审查者
AGENT_MINIMAX_APP_ID=cli_****************
AGENT_MINIMAX_APP_SECRET=********************************

# Codex Agent — 执行者
AGENT_CODEX_APP_ID=cli_****************
AGENT_CODEX_APP_SECRET=********************************

# Codex 飞书机器人（CODEX-32）
CODEX_FEISHU_APP_ID=cli_****************
CODEX_FEISHU_APP_SECRET=********************************
CODEX_FEISHU_USER_OPEN_ID=ou_********************************

# Kimi 飞书机器人（Moonshot AI）
KIMI_FEISHU_APP_ID=cli_****************
KIMI_FEISHU_APP_SECRET=********************************
KIMI_FEISHU_USER_OPEN_ID=ou_********************************
KIMI_API_KEY=sk-********************************
KIMI_MODEL=moonshot-v1-32k

# MiniMax 飞书机器人
MINIMAX_FEISHU_APP_ID=cli_****************
MINIMAX_FEISHU_APP_SECRET=********************************
MINIMAX_FEISHU_USER_OPEN_ID=ou_********************************
MINIMAX_API_KEY=********************************
MINIMAX_GROUP_ID=********************************
MINIMAX_MODEL=MiniMax-Text-01
